{
  "info": {
    "name": "Invoice Service (RetailFlow)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [ { "key": "baseUrl", "value": "http://localhost:8092" } ],
  "item": [
    {
      "name": "Create Invoice",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/invoices",
        "body": { "mode": "raw", "raw": "{\n  \"saleId\": 1,\n  \"amount\": 175.0\n}" }
      }
    },
    { "name": "Get All Invoices", "request": { "method": "GET", "url": "{{baseUrl}}/api/invoices" } },
    { "name": "Get Invoice By Id", "request": { "method": "GET", "url": "{{baseUrl}}/api/invoices/1" } },
    { "name": "Get Invoice By Sale", "request": { "method": "GET", "url": "{{baseUrl}}/api/invoices/sale/1" } },
    { "name": "Get By Status", "request": { "method": "GET", "url": "{{baseUrl}}/api/invoices/status/PENDING" } },
    { "name": "Get By Date Range", "request": { "method": "GET", "url": "{{baseUrl}}/api/invoices/date-range?start=2026-01-01&end=2026-12-31" } },
    { "name": "Get Paginated", "request": { "method": "GET", "url": "{{baseUrl}}/api/invoices/paginated?page=0&size=5" } },
    {
      "name": "Update Invoice",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/invoices/1",
        "body": { "mode": "raw", "raw": "{\n  \"saleId\": 1,\n  \"amount\": 200.0,\n  \"status\": \"PARTIALLY_PAID\"\n}" }
      }
    },
    {
      "name": "Update Status (used by Payment)",
      "request": { "method": "PATCH", "url": "{{baseUrl}}/api/invoices/1/status?status=PAID" }
    },
    { "name": "Cancel Invoice", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/invoices/1" } }
  ]
}
